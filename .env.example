CLIENT_ID=<YOUR REDDIT APP CLIENT ID>
CLIENT_SECRET=<YOUR REDDIT APP CLIENT SECRET>
NEXTAUTH_SECRET=generate one, example with >openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
SIGNING_PRIVATE_KEY=generate one, example with >jose newkey -s 256 -t oct -a HS512

# Database Configuration
# For local development with Docker Compose, use localhost as host
# For containerized app, use 'db' as the service name
# For production, replace with actual database connection string
DATABASE_URL=postgres://troddit:troddit@localhost:5432/troddit

# Database Host Port (for Docker Compose)
# Uncomment and set to avoid conflicts with local Postgres
# DB_HOST_PORT=5433
