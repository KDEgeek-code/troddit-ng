{
  "name": "troddit",
  "version": "0.21.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:prod": "next build",
    "start:prod": "next start",
    "verify:db": "ts-node scripts/verify-db.ts",
    "test:lighthouse": "lighthouse http://localhost:3000 --config-path=./tests/lighthouse-config.json --output=html --output-path=./tests/lighthouse-report.html",
    "test:lighthouse:prod": "concurrently --kill-others --success first \"wait-on http://localhost:3000 && npm run test:lighthouse\" \"npm run start:prod\"",
    "test:pwa": "echo 'Starting PWA tests...' && npm run test:lighthouse && echo 'Open ./tests/lighthouse-report.html to view results'",
    "test:pwa:audit": "node ./tests/lighthouse-pwa-audit-runner.js",
    "test:pwa:prod": "npm run build:prod && concurrently --kill-others --success first \"wait-on http://localhost:3000 && npm run test:pwa:audit\" \"npm run start:prod\"",
    "test:cache": "echo 'Open DevTools Console on the app and paste the contents of ./tests/cache-validation.js'",
    "dev:full": "docker-compose up -d db && npm run dev",
    "test:setup": "docker-compose up -d db && echo 'Database started. Run npm run build && npm run start in another terminal.'",
    "test:db-app-module": "ts-node tests/db-with-app-module.ts",
    "test:media": "echo 'Running media functionality tests...' && node tests/media-integration-test-suite.js",
    "test:media:hls": "echo 'Testing HLS video playback...' && node tests/media-hls-playback-test.js",
    "test:media:images": "echo 'Testing image loading and caching...' && node tests/media-image-caching-validation.js",
    "test:media:controls": "echo 'Testing media controls...' && node tests/media-controls-functionality-test.js",
    "test:media:responsive": "echo 'Testing responsive design...' && node tests/responsive-design-mobile-compatibility.js",
    "test:media:autoplay": "echo 'Testing autoplay behavior...' && node tests/media-autoplay-behavior-test.js",
    "test:media:performance": "echo 'Monitoring media performance...' && node tests/media-performance-monitoring.js",
    "test:media:accessibility": "echo 'Testing media accessibility...' && node tests/media-accessibility-testing.js",
    "test:media:console": "echo 'Open DevTools Console and paste contents of ./tests/browser-console-media-debugger.js'",
    "test:media:manual": "echo 'Follow instructions in ./tests/media-manual-testing-guide.md'",
    "test:media:full": "./scripts/media-test-automation.sh",
    "test:media:ci": "NODE_ENV=test npm run test:media:full -- --headless",
    "test:media:e2e": "playwright test tests/e2e --reporter=line",
    "test:errors": "echo 'Running error resilience tests...' && node tests/error-resilience-integration-test.js",
    "test:rate-limiting": "echo 'Testing rate limiting...' && node tests/rate-limiting-comprehensive-test.js",
    "test:error-boundaries": "echo 'Testing error boundaries...' && node tests/error-boundaries-validation.js",
    "test:offline-behavior": "echo 'Testing offline behavior...' && node tests/offline-behavior-comprehensive-test.js",
    "test:database-resilience": "echo 'Testing database resilience...' && node tests/database-failure-recovery-test.js",
    "test:security-headers": "echo 'Testing security headers...' && node tests/security-headers-csp-validation.js",
    "test:error-console": "echo 'Open DevTools Console and paste contents of ./tests/browser-console-error-debugger.js'",
    "test:error-manual": "echo 'Follow instructions in ./tests/error-resilience-manual-testing-guide.md'",
    "test:resilience:full": "./scripts/error-resilience-test-automation.sh",
    "test:resilience:ci": "NODE_ENV=test npm run test:resilience:full -- --headless"
  },
  "dependencies": {
    "@clerk/nextjs": "^4.29.7",
    "@headlessui/react": "1.5",
    "@react-hook/resize-observer": "^1.2.5",
    "@react-hook/window-size": "^3.0.7",
    "@supabase/supabase-js": "^2.24.0",
    "@tanstack/query-sync-storage-persister": "^4.27.1",
    "@tanstack/react-query": "^4.28.0",
    "@tanstack/react-query-devtools": "^4.28.0",
    "@tanstack/react-query-persist-client": "^4.28.0",
    "@vercel/analytics": "^0.1.6",
    "axios": "^1.8.2",
    "draft-js": "^0.11.7",
    "draftjs-to-html": "^0.9.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "hls.js": "^1.2.5",
    "html-to-react": "^1.4.8",
    "jwt-decode": "^3.1.2",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "markdown-draft-js": "^2.4.0",
    "masonic": "^3.6.4",
    "next": "^14.2.30",
    "next-auth": "^4.22.0",
    "next-cookies": "^2.0.3",
    "next-plausible": "^3.1.4",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "nuka-carousel": "^5.4.0",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-autosuggest": "^10.1.0",
    "react-dom": "^18.2.0",
    "react-draft-wysiwyg": "^1.14.7",
    "react-error-boundary": "^3.1.4",
    "react-hot-toast": "^2.2.0",
    "react-icons": "^4.3.1",
    "react-intersection-observer": "^9.1.0",
    "react-markdown": "^8.0.3",
    "react-switch": "^6.0.0",
    "react-twitter-embed": "^4.0.4",
    "rehype-raw": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/line-clamp": "^0.3.1",
    "@tailwindcss/typography": "^0.5.2",
    "@types/node": "^18.19.0",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.0",
    "@types/react-lazyload": "^3.1.1",
    "autoprefixer": "^10.4.2",
    "concurrently": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.30",
    "lighthouse": "^11.4.0",
    "postcss": "^8.4.7",
    "tailwind-scrollbar": "^1.3.1",
    "tailwindcss": "^3.0.24",
    "typescript": "^5.9.2",
    "ts-node": "^10.9.2",
    "wait-on": "^7.0.1"
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
