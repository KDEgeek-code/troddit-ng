{
  "name": "troddit",
  "version": "0.21.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:prod": "next build",
    "start:prod": "next start",
    "test:lighthouse": "lighthouse http://localhost:3000 --config-path=./tests/lighthouse-config.json --output=html --output-path=./tests/lighthouse-report.html",
    "test:lighthouse:prod": "concurrently --kill-others --success first \"wait-on http://localhost:3000 && npm run test:lighthouse\" \"npm run start:prod\"",
    "test:pwa": "echo 'Starting PWA tests...' && npm run test:lighthouse && echo 'Open ./tests/lighthouse-report.html to view results'",
    "test:pwa:prod": "npm run build:prod && concurrently --kill-others --success first \"wait-on http://localhost:3000 && npm run test:lighthouse\" \"npm run start:prod\"",
    "test:cache": "echo 'Open DevTools Console on the app and paste the contents of ./tests/cache-validation.js'",
    "dev:full": "docker-compose up -d db && npm run dev",
    "test:setup": "docker-compose up -d db && echo 'Database started. Run npm run build && npm run start in another terminal.'"
  },
  "dependencies": {
    "@clerk/nextjs": "^4.29.7",
    "@headlessui/react": "1.5",
